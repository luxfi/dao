{
  "name": "@luxfi/governance-hooks",
  "version": "0.1.0",
  "description": "Shared governance hooks for Lux DAO ecosystem",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "wagmi": ">=2",
    "viem": ">=2"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "wagmi": "^2.0.0",
    "viem": "^2.0.0"
  },
  "keywords": [
    "lux",
    "dao",
    "governance",
    "wagmi",
    "hooks"
  ],
  "author": "Lux Industries Inc",
  "license": "MIT"
}
